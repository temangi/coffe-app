# Обязательно исключаем зависимости
node_modules/

# Исключаем кэш Expo и Metro
.expo/
dist/
web-build/

# Исключаем локальные настройки и секреты
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Исключаем системные файлы Mac
.DS_Store

# Исключаем логи ошибок
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Исключаем временные файлы TypeScript
*.tsbuildinfo